{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "sl",
      "camelcase": "Sl",
      "scope": "source.sl",
      "path": ".",
      "file-types": ["sl"],
      "injection-regex": "^sl$"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "tree-sitter grammar for FEGate SL (FFS Script Language)",
    "authors": [{ "name": "codegraph" }]
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
