{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\sonar-guard.sh'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\write-approval-reminder.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\dict-sync-check.sh'",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\gate-check.sh'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\dict-blk-announce.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash 'D:\\Fork\\claude-personal-integrated-workflow\\.codex\\hooks\\session-start.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
